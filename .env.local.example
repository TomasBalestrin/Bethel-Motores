# Public — expostas no bundle client (seguras desde que RLS esteja ativo)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Server only — nunca importadas em arquivos "use client"
# service_role faz bypass completo de RLS — use APENAS em src/app/api/*
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# Webhook secrets — validação inbound (Fluxon, Meta Ads, etc.)
WEBHOOK_SECRET_FLUXON=
