{
  "extends": ["next/core-web-vitals", "next/typescript"],
  "rules": {
    "no-restricted-imports": [
      "error",
      {
        "patterns": [
          {
            "group": ["@/lib/supabase/admin", "@/lib/supabase/admin.*", "**/lib/supabase/admin"],
            "message": "admin.ts usa service_role e só pode ser importado em arquivos dentro de src/app/api/"
          }
        ]
      }
    ]
  },
  "overrides": [
    {
      "files": ["src/app/api/**/*.{ts,tsx}"],
      "rules": {
        "no-restricted-imports": "off"
      }
    },
    {
      "files": ["src/lib/supabase/admin.ts"],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ]
}
